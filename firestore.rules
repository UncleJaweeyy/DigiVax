rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function hasProfile() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isActiveStaff() {
      return hasProfile()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == "Active";
    }

    function isAdmin() {
      return isActiveStaff()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    match /users/{userId} {
      allow read: if isSelf(userId) || isAdmin();
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (
          isSelf(userId)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(["forcePasswordChange", "updatedAt"])
        );
    }

    match /vaccinationRecords/{recordId} {
      allow read: if isActiveStaff();
      allow create: if isActiveStaff()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status in ["Pending Review", "Completed"];
      allow update: if isAdmin()
        || (
          isActiveStaff()
          && resource.data.createdBy == request.auth.uid
          && request.resource.data.createdBy == resource.data.createdBy
        );
      allow delete: if isAdmin();
    }
  }
}
