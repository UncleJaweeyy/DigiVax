{
  "apphosting": [
    {
      "backendId": "digivax",
      "rootDir": ".",
      "ignore": [
        "node_modules",
        ".git",
        ".next",
        ".python",
        ".venv",
        "**/.venv",
        "**/__pycache__",
        "python-*-amd64.exe",
        "thesis_extracted_text.txt",
        "*.log",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "functions"
      ],
      "alwaysDeployFromSource": true
    }
  ],
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
