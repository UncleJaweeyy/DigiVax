NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Optional for local Firebase Admin SDK server actions.
# App Hosting uses its runtime service account automatically.
# Recommended locally: download a Firebase service account JSON and point to it.
GOOGLE_APPLICATION_CREDENTIALS=

# Alternative: paste individual service account values.
FIREBASE_CLIENT_EMAIL=
# Paste the service account private key as one line with \n between lines.
FIREBASE_PRIVATE_KEY=

# Required for server-side AES-256-GCM record encryption.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DIGIVAX_RECORD_ENCRYPTION_KEY=
DIGIVAX_RECORD_ENCRYPTION_KEY_ID=record-key-v1

# Admin-only decrypted data inspector. Keep false except during short dev validation sessions.
DIGIVAX_ENABLE_DEV_DECRYPT_VIEW=false

# OCR / ML backend handshake.
# Set OCR_API_URL to the Cloud Run/FastAPI endpoint that accepts multipart form-data.
# For local default PaddleOCR demo, run backend/ocr/server.py and use http://127.0.0.1:8000/ocr.
# For local custom medical OCR, run backend/medical-ocr/api_server.py and use http://127.0.0.1:8081/ocr.
OCR_API_URL=
OCR_API_KEY=
OCR_USE_MOCK=false

# Optional real BioBERT semantic embedding service.
# Run backend/semantic-search locally on port 8090 or deploy it separately.
BIOBERT_API_URL=
BIOBERT_API_KEY=
